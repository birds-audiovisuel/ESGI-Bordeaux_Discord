# Discord Bot Configuration
DISCORD_TOKEN=your_discord_bot_token_here
CLIENT_ID=your_discord_application_client_id_here

# Développement uniquement - pour déploiement rapide sur un serveur spécifique
# En production, laissez vide pour déploiement global
GUILD_ID=

# MyGES API Service Configuration
MYGES_API_URL=http://localhost:3001
MYGES_API_KEY=your_api_service_key_here

# Database Configuration
DATABASE_PATH=./data/bot.db

# Bot Configuration Global
BOT_PREFIX=!
LOG_LEVEL=info

# Canaux par défaut (optionnel - peuvent être configurés par serveur)
DEFAULT_WELCOME_CHANNEL_NAME=accueil
DEFAULT_LOG_CHANNEL_NAME=logs-bot

# Security
JWT_SECRET=your_jwt_secret_here_for_user_sessions
HASH_SALT_ROUNDS=12

# Multi-Server Configuration
MAX_SERVERS=100
ENABLE_AUTO_SETUP=false

# Bot Owner (pour commandes globales)
BOT_OWNER_ID=your_discord_user_id_here